<ui:FluentWindow x:Class="GamerGuardian.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GamerGuardian - Settings"
        Closing="OnWindowClosing"
        Width="820" Height="720"
        MinWidth="680" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="GamerGuardian">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Games24"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <DockPanel Grid.Row="1" Margin="20,8,20,16" LastChildFill="True">

            <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:HyperlinkButton x:Name="VersionLink" Grid.Column="0"
                                    NavigateUri="https://github.com/carterscode/GamerGuardian/releases"
                                    Padding="4,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                    FontSize="11"
                                    ToolTip="Open releases page"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="PendingStatusText"
                               Text="No pending changes"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    <ui:Button x:Name="VerifyAllButton" Content="Verify all" MinWidth="96" Margin="0,0,8,0" Click="VerifyAllButton_Click"
                               ToolTip="Re-read every monitored setting and report the current state vs your preferences in the change log. Does not apply any changes -- safe to click any time."/>
                    <ui:Button x:Name="CancelButton" Content="Cancel" MinWidth="96" Margin="0,0,8,0" Click="CancelButton_Click"
                               ToolTip="Discard every pending change. The committed configuration on disk is not modified."/>
                    <ui:Button x:Name="ApplyButton" Content="Apply" MinWidth="96" Margin="0,0,8,0" Click="ApplyButton_Click"
                               ToolTip="Commit pending changes to disk and run the apply pass. Window stays open."/>
                    <ui:Button x:Name="SaveButton" Content="Save &amp; close" Appearance="Primary" MinWidth="120" Click="SaveButton_Click"
                               ToolTip="Commit pending changes, run the apply pass, then close. If no changes are pending, just closes."/>
                </StackPanel>
            </Grid>

            <TabControl x:Name="MainTabs" Padding="0,8,0,0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch">

                <TabItem Header="General"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,8,0">
                        <StackPanel>
                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="One-click Recommended setup" FontWeight="SemiBold"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="12"
                                                   Text="Applies GamerGuardian's gaming-recommended preset to every setting it knows about: sets the recommended Want value, turns Monitor on, and turns Auto-apply silently on. Skips Memory Integrity / VBS (security tradeoff) and the optional UWP AI app removals (irreversible). Idempotent -- only mutates settings that aren't already in the recommended state, so re-running it after a future update picks up only the new settings."/>
                                        <TextBlock x:Name="RecommendedStatusText"
                                                   Margin="0,8,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Content="Apply recommended"
                                               Appearance="Primary" MinWidth="150"
                                               VerticalAlignment="Center"
                                               Click="ApplyRecommendedPresetButton_Click"
                                               ToolTip="Stages the recommended preset to your draft. Review the per-tab changes, then click Apply / Save &amp; close to commit."/>
                                </Grid>
                            </ui:Card>

                            <ui:Card Padding="16" Margin="0,0,0,8">
                                <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Theme"/>
                                        <TextBlock Text="Use system, force light, or force dark."
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                    <ComboBox x:Name="ThemeCombo" Grid.Column="1" Width="160" SelectionChanged="ThemeCombo_SelectionChanged"/>
                                </Grid>

                                <CheckBox x:Name="LaunchAtStartupCheck" Content="Launch at Windows startup" Margin="0,4,0,4"/>
                                <CheckBox x:Name="ConsolidateCheck" Content="Group multiple drifts into one notification" Margin="0,4,0,4"/>
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" x:Name="CheckForUpdatesCheck" Content="Check for updates on startup" VerticalAlignment="Center"/>
                                    <ui:Button Grid.Column="1" x:Name="CheckUpdatesNowButton" Content="Check now" MinWidth="110" Click="CheckUpdatesNowButton_Click"/>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Change log"/>
                                        <TextBlock Text="Every applied change (manual or silent) is recorded with a timestamp, before/after values, and verification status."
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Content="Open change log" MinWidth="140" Click="OpenChangeLogButton_Click"/>
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Polling interval"/>
                                        <TextBlock Text="How often the monitor compares current settings against your preferences."
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ui:NumberBox x:Name="PollSecondsBox" Width="120" Minimum="5" Maximum="3600" Value="30"/>
                                        <TextBlock Text="seconds" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ui:Card>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Global gaming"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,8,0">
                        <StackPanel>
                            <ItemsControl x:Name="GlobalTogglesList" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Card Padding="16" Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <Border Visibility="{Binding RebootBadgeVisibility}"
                                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                                CornerRadius="3" Padding="6,1"
                                                                HorizontalAlignment="Left"
                                                                Margin="0,4,0,0">
                                                            <TextBlock Text="reboot required"
                                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                                       FontSize="10" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   FontSize="12" Margin="0,3,0,0"
                                                                   TextWrapping="Wrap"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding CurrentText}"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       FontSize="11" Margin="0,0,12,0"/>
                                                            <TextBlock Text="{Binding DefaultText}"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       FontSize="11"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Vertical">
                                                        <CheckBox Content="Monitor" IsChecked="{Binding Monitor}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                            <TextBlock Text="Want:" Margin="0,4,8,0"/>
                                                            <RadioButton GroupName="{Binding GroupName}" Content="{Binding OnLabel}" IsChecked="{Binding DesiredOn}" Margin="0,0,8,0"/>
                                                            <RadioButton GroupName="{Binding GroupName}" Content="{Binding OffLabel}" IsChecked="{Binding DesiredOff}"/>
                                                        </StackPanel>
                                                        <CheckBox Content="Auto-apply silently" IsChecked="{Binding AutoApply}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Expander Header="Learn more" Margin="0,8,0,0"
                                                          Visibility="{Binding LearnMoreVisibility}">
                                                    <TextBlock Text="{Binding LearnMoreContent}"
                                                               TextWrapping="Wrap" FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="8,8,8,8"/>
                                                </Expander>
                                            </StackPanel>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ui:Card Padding="16" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Power plan" FontWeight="SemiBold"/>
                                        <TextBlock Text="Active Windows power scheme — High Performance keeps CPU clocks elevated."
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="12" Margin="0,3,0,0"
                                                   TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock x:Name="PowerPlanCurrentText"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       FontSize="11" Margin="0,0,12,0"/>
                                            <TextBlock Text="Default: Balanced"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Vertical">
                                        <CheckBox x:Name="PowerPlanMonitorCheck" Content="Monitor"
                                                  Checked="PowerPlanMonitorCheck_Changed"
                                                  Unchecked="PowerPlanMonitorCheck_Changed"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                            <TextBlock Text="Want:" Margin="0,6,8,0"/>
                                            <ComboBox x:Name="PowerPlanCombo" Width="240"
                                                      SelectionChanged="PowerPlanCombo_SelectionChanged"/>
                                        </StackPanel>
                                        <CheckBox x:Name="PowerPlanAutoApplyCheck" Content="Auto-apply silently"
                                                  Checked="PowerPlanAutoApplyCheck_Changed"
                                                  Unchecked="PowerPlanAutoApplyCheck_Changed"/>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Privacy"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,8,0">
                        <StackPanel>
                            <ui:Card Padding="16" Margin="0,0,0,8">
                                <TextBlock Text="Privacy and telemetry toggles Windows often re-enables after feature updates. Each is monitored against your preference and (optionally) re-applied when it drifts back."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </ui:Card>
                            <ItemsControl x:Name="PrivacyTogglesList" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Card Padding="16" Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <Border Visibility="{Binding RebootBadgeVisibility}"
                                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                                CornerRadius="3" Padding="6,1"
                                                                HorizontalAlignment="Left"
                                                                Margin="0,4,0,0">
                                                            <TextBlock Text="reboot required"
                                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                                       FontSize="10" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   FontSize="12" Margin="0,3,0,0"
                                                                   TextWrapping="Wrap"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding CurrentText}"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       FontSize="11" Margin="0,0,12,0"/>
                                                            <TextBlock Text="{Binding DefaultText}"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       FontSize="11"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Vertical">
                                                        <CheckBox Content="Monitor" IsChecked="{Binding Monitor}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                            <TextBlock Text="Want:" Margin="0,4,8,0"/>
                                                            <RadioButton GroupName="{Binding GroupName}" Content="{Binding OnLabel}" IsChecked="{Binding DesiredOn}" Margin="0,0,8,0"/>
                                                            <RadioButton GroupName="{Binding GroupName}" Content="{Binding OffLabel}" IsChecked="{Binding DesiredOff}"/>
                                                        </StackPanel>
                                                        <CheckBox Content="Auto-apply silently" IsChecked="{Binding AutoApply}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Expander Header="Learn more" Margin="0,8,0,0"
                                                          Visibility="{Binding LearnMoreVisibility}">
                                                    <TextBlock Text="{Binding LearnMoreContent}"
                                                               TextWrapping="Wrap" FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="8,8,8,8"/>
                                                </Expander>
                                            </StackPanel>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Windows services"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,8,0">
                        <StackPanel>
                            <ui:Card Padding="16" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Stop and disable Windows services that run by default but typically aren't needed for gaming. Each service is monitored against your preference and (optionally) re-applied when Windows or another app re-enables it."
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="One-click preset:" Margin="0,4,12,0"/>
                                        <RadioButton x:Name="ServicesPresetGaming" GroupName="services_preset"
                                                     Content="Gaming optimized" Margin="0,0,12,0"
                                                     Checked="ServicesPresetGaming_Checked"/>
                                        <RadioButton x:Name="ServicesPresetDefault" GroupName="services_preset"
                                                     Content="Default"
                                                     Checked="ServicesPresetDefault_Checked"/>
                                    </StackPanel>
                                    <TextBlock Text="Tip: the Gaming preset toggles the recommended subset; non-recommended services stay where you set them."
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </StackPanel>
                            </ui:Card>
                            <ItemsControl x:Name="ServicesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Card Padding="16" Margin="0,0,0,8">
                                            <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    <WrapPanel Margin="0,4,0,0">
                                                        <Border Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                                                CornerRadius="3" Padding="6,1" Margin="0,0,6,4">
                                                            <TextBlock Text="{Binding ServiceName}"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       FontSize="10" FontFamily="Consolas"/>
                                                        </Border>
                                                        <Border Visibility="{Binding RecommendedBadgeVisibility}"
                                                                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                                                                CornerRadius="3" Padding="6,1" Margin="0,0,6,4">
                                                            <TextBlock Text="recommended"
                                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                                       FontSize="10" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Visibility="{Binding RebootBadgeVisibility}"
                                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                                CornerRadius="3" Padding="6,1" Margin="0,0,6,4">
                                                            <TextBlock Text="reboot required"
                                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                                       FontSize="10" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Visibility="{Binding NotInstalledBadgeVisibility}"
                                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                                CornerRadius="3" Padding="6,1" Margin="0,0,6,4">
                                                            <TextBlock Text="not installed"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       FontSize="10" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </WrapPanel>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="12" Margin="0,3,0,0"
                                                               TextWrapping="Wrap"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                        <TextBlock Text="{Binding CurrentText}"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   FontSize="11" Margin="0,0,12,0"/>
                                                        <TextBlock Text="{Binding DefaultText}"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Vertical"
                                                            IsEnabled="{Binding IsInstalled}">
                                                    <CheckBox Content="Monitor" IsChecked="{Binding Monitor}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                        <TextBlock Text="Want:" Margin="0,4,8,0"/>
                                                        <RadioButton GroupName="{Binding GroupName}" Content="Default" IsChecked="{Binding DesiredDefault}" Margin="0,0,6,0"/>
                                                        <RadioButton GroupName="{Binding GroupName}" Content="Manual" IsChecked="{Binding DesiredManual}" Margin="0,0,6,0"/>
                                                        <RadioButton GroupName="{Binding GroupName}" Content="Disabled" IsChecked="{Binding DesiredDisabled}"/>
                                                    </StackPanel>
                                                    <CheckBox Content="Auto-apply silently" IsChecked="{Binding AutoApply}"/>
                                                </StackPanel>
                                            </Grid>
                                                <Expander Header="Learn more" Margin="0,8,0,0"
                                                          Visibility="{Binding LearnMoreVisibility}">
                                                    <TextBlock Text="{Binding LearnMoreContent}"
                                                               TextWrapping="Wrap" FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="8,8,8,8"/>
                                                </Expander>
                                            </StackPanel>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Windows AI"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,8,0">
                        <StackPanel>
                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Windows AI lockdown" FontWeight="SemiBold"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12"
                                               Text="Group-policy switches for Copilot, Recall, Click-to-Do, Edge Copilot and Notepad/Paint AI. Off means GamerGuardian writes the documented disable policy; On (default) means the policy is removed so Windows falls back to its default. Every change here is reversible by deleting the same registry values. Inspired by github.com/zoicware/RemoveWindowsAI but stays in the safe policy-toggle lane."/>
                                </StackPanel>
                            </ui:Card>

                            <!-- Policy toggles, same template as Global gaming -->
                            <ItemsControl x:Name="WindowsAiRows" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Card Padding="16" Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <Border Visibility="{Binding RebootBadgeVisibility}"
                                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                                CornerRadius="3" Padding="6,1"
                                                                HorizontalAlignment="Left"
                                                                Margin="0,4,0,0">
                                                            <TextBlock Text="reboot required"
                                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                                       FontSize="10" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   FontSize="12" Margin="0,3,0,0"
                                                                   TextWrapping="Wrap"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding CurrentText}"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       FontSize="11" Margin="0,0,12,0"/>
                                                            <TextBlock Text="{Binding DefaultText}"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       FontSize="11"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Vertical">
                                                        <CheckBox Content="Monitor" IsChecked="{Binding Monitor}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                            <TextBlock Text="Want:" Margin="0,4,8,0"/>
                                                            <RadioButton GroupName="{Binding GroupName}" Content="{Binding OnLabel}" IsChecked="{Binding DesiredOn}" Margin="0,0,8,0"/>
                                                            <RadioButton GroupName="{Binding GroupName}" Content="{Binding OffLabel}" IsChecked="{Binding DesiredOff}"/>
                                                        </StackPanel>
                                                        <CheckBox Content="Auto-apply silently" IsChecked="{Binding AutoApply}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Expander Header="Learn more" Margin="0,8,0,0"
                                                          Visibility="{Binding LearnMoreVisibility}">
                                                    <TextBlock Text="{Binding LearnMoreContent}"
                                                               TextWrapping="Wrap" FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="8,8,8,8"/>
                                                </Expander>
                                            </StackPanel>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Windows AI apps (UWP removal)" FontWeight="SemiBold"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12"
                                               Text="One-way removal of Windows AI UWP packages. Drift only flags installed -> remove; GamerGuardian cannot reinstall removed packages (use the Microsoft Store). Tick Auto-apply if you want re-provisioned packages re-removed automatically on the next tick after a Windows Update."/>
                                </StackPanel>
                            </ui:Card>

                            <ItemsControl x:Name="WindowsAiAppRows" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Card Padding="16" Margin="0,0,0,8">
                                            <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding PackageName}"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                               FontFamily="Consolas" FontSize="11" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="12" Margin="0,3,0,0"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding CurrentText}"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                               FontSize="11" Margin="0,6,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Vertical">
                                                    <CheckBox Content="Monitor" IsChecked="{Binding Monitor}"/>
                                                    <CheckBox Content="Remove (one-way)" IsChecked="{Binding DesiredRemoved}" Margin="0,4,0,4"/>
                                                    <CheckBox Content="Auto-apply silently" IsChecked="{Binding AutoApply}"/>
                                                </StackPanel>
                                            </Grid>
                                                <Expander Header="Learn more" Margin="0,8,0,0"
                                                          Visibility="{Binding LearnMoreVisibility}">
                                                    <TextBlock Text="{Binding LearnMoreContent}"
                                                               TextWrapping="Wrap" FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="8,8,8,8"/>
                                                </Expander>
                                            </StackPanel>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Display"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,8,0">
                        <ItemsControl x:Name="DisplaysList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ui:CardExpander Header="{Binding HeaderText}" Margin="0,0,0,8" IsExpanded="True">
                                        <ui:CardExpander.Icon>
                                            <ui:SymbolIcon Symbol="Desktop24"/>
                                        </ui:CardExpander.Icon>
                                        <StackPanel Margin="0,4,0,0">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       FontSize="12" Margin="0,0,0,12"/>

                                            <TextBlock Text="HDR" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                            <CheckBox Content="Monitor this setting" IsChecked="{Binding HdrMonitor}"/>
                                            <CheckBox Content="Desired: Enabled" IsChecked="{Binding HdrDesiredOn}"/>
                                            <CheckBox Content="Auto-apply silently when it drifts" IsChecked="{Binding HdrAutoApply}"/>

                                            <Separator Margin="0,12,0,8"/>
                                            <TextBlock Text="Refresh Rate" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                            <CheckBox Content="Monitor this setting" IsChecked="{Binding RefreshMonitor}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                <RadioButton GroupName="{Binding RateGroupName}" Content="Maximum supported" IsChecked="{Binding RefreshUseMax}" Margin="0,0,16,0"/>
                                                <RadioButton GroupName="{Binding RateGroupName}" Content="Fixed:" IsChecked="{Binding RefreshUseFixed}" Margin="0,0,8,0"/>
                                                <ComboBox ItemsSource="{Binding AvailableHz}" SelectedItem="{Binding FixedHz}" Width="80" IsEnabled="{Binding RefreshUseFixed}"/>
                                                <TextBlock Text="Hz" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <CheckBox Content="Auto-apply silently when it drifts" IsChecked="{Binding RefreshAutoApply}"/>

                                            <Separator Margin="0,12,0,8"/>
                                            <TextBlock Text="Resolution" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                            <CheckBox Content="Monitor this setting" IsChecked="{Binding ResolutionMonitor}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                <TextBlock Text="Pin to:" Margin="0,6,8,0"/>
                                                <ComboBox ItemsSource="{Binding AvailableResolutions}" SelectedItem="{Binding DesiredResolution}" Width="160" IsEnabled="{Binding ResolutionMonitor}"/>
                                            </StackPanel>
                                            <CheckBox Content="Auto-apply silently when it drifts" IsChecked="{Binding ResolutionAutoApply}"/>
                                        </StackPanel>
                                    </ui:CardExpander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="CPU / Power"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,8,0">
                        <StackPanel>
                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Detected CPU" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="CpuDetectedText" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="CpuTierText" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ui:Card>

                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Gaming power plan" FontWeight="SemiBold"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="Switch to the best-matching prebuilt Windows plan, or build a GamerGuardian-authored plan tuned for your CPU. Your existing Windows plans are never modified or deleted -- the app only creates or re-tunes its own plan, and you can switch back at any time."/>
                                        <TextBlock x:Name="CpuPlanStatusText" Margin="0,8,0,0" FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <ui:Button x:Name="SuggestPrebuiltButton" Content="Suggest best prebuilt"
                                                   MinWidth="180" Margin="0,0,0,8"
                                                   Click="SuggestPrebuiltButton_Click"/>
                                        <ui:Button x:Name="BuildOptimizedButton" Content="Build optimized plan"
                                                   Appearance="Primary" MinWidth="180"
                                                   Click="BuildOptimizedButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>

                            <ui:Card x:Name="CcdDependencyCard" Padding="16" Margin="0,0,0,8" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Dual-CCD routing dependencies" FontWeight="SemiBold"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="On this CPU the power plan is necessary but not sufficient. Game threads only stay on the cache CCD when these are also in place:"/>
                                    <StackPanel x:Name="CcdDependencyList" Margin="0,8,0,0"/>
                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Text="State is read once when this window opens. Restart GamerGuardian to re-check."/>
                                </StackPanel>
                            </ui:Card>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Recommended BIOS"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,8,0">
                        <StackPanel>
                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Recommended BIOS settings" FontWeight="SemiBold"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="Advisory only -- GamerGuardian cannot read or change BIOS settings. Verify these against your motherboard manual. Recommendations are keyed to your detected CPU."/>
                                </StackPanel>
                            </ui:Card>
                            <ui:Card Padding="16" Margin="0,0,0,8">
                                <StackPanel x:Name="BiosGuidanceList"/>
                            </ui:Card>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
