<ui:FluentWindow x:Class="GamerGuardian.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GamerGuardian - Settings"
        Width="780" Height="760"
        MinWidth="640" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="GamerGuardian">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Games24"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <DockPanel Grid.Row="1" Margin="20,8,20,16" LastChildFill="True">

            <Border DockPanel.Dock="Bottom" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Cancel" MinWidth="96" Margin="0,0,8,0" Click="CancelButton_Click"/>
                    <ui:Button Content="Save" Appearance="Primary" MinWidth="96" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <StackPanel>

                    <TextBlock Text="General"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="0,4,0,8"/>
                    <ui:Card Padding="16" Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Theme"/>
                                    <TextBlock Text="Use system, force light, or force dark."
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12"/>
                                </StackPanel>
                                <ComboBox x:Name="ThemeCombo" Grid.Column="1" Width="160" SelectionChanged="ThemeCombo_SelectionChanged"/>
                            </Grid>

                            <CheckBox x:Name="LaunchAtStartupCheck" Content="Launch at Windows startup" Margin="0,4,0,4"/>
                            <CheckBox x:Name="ConsolidateCheck" Content="Group multiple drifts into one notification" Margin="0,4,0,4"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Check interval"/>
                                    <TextBlock Text="How often to compare current settings against your preferences."
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:NumberBox x:Name="PollSecondsBox" Width="120" Minimum="5" Maximum="3600" Value="30"/>
                                    <TextBlock Text="seconds" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <TextBlock Text="Global gaming settings"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="0,4,0,8"/>
                    <ItemsControl x:Name="GlobalTogglesList" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding CurrentText}"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       FontSize="12" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="16,0,0,0">
                                            <CheckBox Content="Monitor" IsChecked="{Binding Monitor}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                <TextBlock Text="Want:" Margin="0,4,8,0"/>
                                                <RadioButton GroupName="{Binding GroupName}" Content="On" IsChecked="{Binding DesiredOn}" Margin="0,0,8,0"/>
                                                <RadioButton GroupName="{Binding GroupName}" Content="Off" IsChecked="{Binding DesiredOff}"/>
                                            </StackPanel>
                                            <CheckBox Content="Auto-apply silently" IsChecked="{Binding AutoApply}"/>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ui:Card Padding="16" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Power plan" FontWeight="SemiBold"/>
                                <TextBlock x:Name="PowerPlanCurrentText"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="16,0,0,0">
                                <CheckBox x:Name="PowerPlanMonitorCheck" Content="Monitor"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                    <TextBlock Text="Want:" Margin="0,6,8,0"/>
                                    <ComboBox x:Name="PowerPlanCombo" Width="180"/>
                                </StackPanel>
                                <CheckBox x:Name="PowerPlanAutoApplyCheck" Content="Auto-apply silently"/>
                            </StackPanel>
                        </Grid>
                    </ui:Card>

                    <TextBlock Text="Per-display settings"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="0,4,0,8"/>
                    <ItemsControl x:Name="DisplaysList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:CardExpander Header="{Binding HeaderText}" Margin="0,0,0,8" IsExpanded="True">
                                    <ui:CardExpander.Icon>
                                        <ui:SymbolIcon Symbol="Desktop24"/>
                                    </ui:CardExpander.Icon>
                                    <StackPanel Margin="0,4,0,0">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="12" Margin="0,0,0,12"/>

                                        <TextBlock Text="HDR" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <CheckBox Content="Monitor this setting" IsChecked="{Binding HdrMonitor}"/>
                                        <CheckBox Content="Desired: ON" IsChecked="{Binding HdrDesiredOn}"/>
                                        <CheckBox Content="Auto-apply silently when it drifts" IsChecked="{Binding HdrAutoApply}"/>

                                        <Separator Margin="0,12,0,8"/>
                                        <TextBlock Text="Refresh Rate" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <CheckBox Content="Monitor this setting" IsChecked="{Binding RefreshMonitor}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                            <RadioButton GroupName="{Binding RateGroupName}" Content="Maximum supported" IsChecked="{Binding RefreshUseMax}" Margin="0,0,16,0"/>
                                            <RadioButton GroupName="{Binding RateGroupName}" Content="Fixed:" IsChecked="{Binding RefreshUseFixed}" Margin="0,0,8,0"/>
                                            <ComboBox ItemsSource="{Binding AvailableHz}" SelectedItem="{Binding FixedHz}" Width="80" IsEnabled="{Binding RefreshUseFixed}"/>
                                            <TextBlock Text="Hz" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <CheckBox Content="Auto-apply silently when it drifts" IsChecked="{Binding RefreshAutoApply}"/>

                                        <Separator Margin="0,12,0,8"/>
                                        <TextBlock Text="Resolution" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <CheckBox Content="Monitor this setting" IsChecked="{Binding ResolutionMonitor}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                            <TextBlock Text="Pin to:" Margin="0,6,8,0"/>
                                            <ComboBox ItemsSource="{Binding AvailableResolutions}" SelectedItem="{Binding DesiredResolution}" Width="160" IsEnabled="{Binding ResolutionMonitor}"/>
                                        </StackPanel>
                                        <CheckBox Content="Auto-apply silently when it drifts" IsChecked="{Binding ResolutionAutoApply}"/>
                                    </StackPanel>
                                </ui:CardExpander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
