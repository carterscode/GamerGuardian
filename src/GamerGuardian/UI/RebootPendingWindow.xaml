<ui:FluentWindow x:Class="GamerGuardian.UI.RebootPendingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GamerGuardian"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Reboot pending">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="ArrowSync24"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="20,8,20,16">
            <TextBlock Text="Settings applied — reboot to take effect"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                GamerGuardian auto-applied registry changes for the following settings. Windows needs a reboot for them to actually take effect.
            </TextBlock>
            <ItemsControl x:Name="ItemsList" Margin="0,0,0,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Margin="0,2,0,0"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="LaterButton" Content="Later" MinWidth="90" Margin="0,0,8,0" Click="LaterButton_Click"/>
                <ui:Button x:Name="RebootButton" Content="Reboot now" Appearance="Primary" MinWidth="110" Click="RebootButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
