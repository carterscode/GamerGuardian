<ui:FluentWindow x:Class="GamerGuardian.UI.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GamerGuardian"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="GamerGuardian">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Warning24"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="20,8,20,16">
            <TextBlock x:Name="HeaderText"
                       Text="Monitored settings have drifted"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>
            <ItemsControl x:Name="ItemsList" Margin="0,0,0,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding Description}" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Now: " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{Binding CurrentValue}" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                                    <TextBlock Text="   →   " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="Want: " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{Binding DesiredValue}" Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="DismissButton" Content="Dismiss" MinWidth="90" Margin="0,0,8,0" Click="DismissButton_Click"/>
                <ui:Button x:Name="ApplyButton" Content="Apply All" Appearance="Primary" MinWidth="90" Click="ApplyButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
