<Window x:Class="GamerGuardian.UI.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GamerGuardian"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#1f1f1f"
        Foreground="#f0f0f0"
        FontFamily="Segoe UI"
        FontSize="13">
    <Border Padding="16" BorderThickness="1" BorderBrush="#3a3a3a">
        <StackPanel>
            <TextBlock Text="Display settings have drifted" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ItemsControl x:Name="ItemsList" Margin="0,0,0,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2a2a2a" Padding="10" Margin="0,0,0,6" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="{Binding Description}" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,2,0,0">
                                    <Run Text="Now: "/><Run Text="{Binding CurrentValue}" Foreground="#ff8a65"/>
                                    <Run Text="   →   "/>
                                    <Run Text="Want: "/><Run Text="{Binding DesiredValue}" Foreground="#81c784"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="DismissButton" Content="Dismiss" Padding="14,6" Margin="0,0,8,0" Click="DismissButton_Click"/>
                <Button x:Name="ApplyButton" Content="Apply All" Padding="14,6" Click="ApplyButton_Click" Background="#2e7d32" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
